<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AddLutemons">

    <RadioGroup
        android:id="@+id/chooseColorGroup"
        android:layout_width="292dp"
        android:layout_height="248dp"
        tools:layout_editor_absoluteX="60dp"
        tools:layout_editor_absoluteY="56dp">

        <RadioButton
            android:id="@+id/pinkRb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="pinkki" />

        <RadioButton
            android:id="@+id/whiteRb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="valkoinen" />

        <RadioButton
            android:id="@+id/greenRb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="vihreä" />

        <RadioButton
            android:id="@+id/orangeRb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="oranssi" />

        <RadioButton
            android:id="@+id/blackRb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="musta" />
    </RadioGroup>

    <EditText
        android:id="@+id/nameLutemonText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ems="10"
        android:hint="Nimeä lutemon"
        android:inputType="text"
        tools:layout_editor_absoluteX="95dp"
        tools:layout_editor_absoluteY="373dp" />

    <Button
        android:id="@+id/addLutemonBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#CC88B6"
        android:text="Lisää uusi Lutemon"
        android:textSize="20sp"
        tools:layout_editor_absoluteX="92dp"
        tools:layout_editor_absoluteY="466dp" />
</androidx.constraintlayout.widget.ConstraintLayout>