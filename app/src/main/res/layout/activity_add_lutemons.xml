<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AddLutemons">

    <RadioGroup
        android:id="@+id/chooseColorGroup"
        android:layout_width="292dp"
        android:layout_height="248dp"
        android:layout_marginTop="80dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <RadioButton
            android:id="@+id/pinkRb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="pinkki" />

        <RadioButton
            android:id="@+id/whiteRb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="valkoinen" />

        <RadioButton
            android:id="@+id/greenRb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="vihreä" />

        <RadioButton
            android:id="@+id/orangeRb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="oranssi" />

        <RadioButton
            android:id="@+id/blackRb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="musta" />
    </RadioGroup>

    <EditText
        android:id="@+id/nameLutemonText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ems="10"
        android:hint="Nimeä lutemon"
        android:inputType="text"
        app:layout_constraintBottom_toTopOf="@+id/addLutemonBtn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/chooseColorGroup" />

    <Button
        android:id="@+id/addLutemonBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="252dp"
        android:backgroundTint="#CC88B6"
        android:onClick="addLutemonToList"
        android:text="Lisää uusi Lutemon"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/inputAllInfoText"
        android:layout_width="299dp"
        android:layout_height="128dp"
        android:gravity="center_horizontal"
        android:soundEffectsEnabled="true"
        android:textColor="#213DDC"
        android:textSize="24sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/addLutemonBtn" />

    <Button
        android:id="@+id/goBackBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:backgroundTint="#CC88B6"
        android:onClick="backToMainActivity"
        android:text="Palaa"
        app:layout_constraintBottom_toTopOf="@+id/chooseColorGroup"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />
</androidx.constraintlayout.widget.ConstraintLayout>