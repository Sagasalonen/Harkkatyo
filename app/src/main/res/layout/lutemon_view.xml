<?xml version="1.0" encoding="utf-8"?>
<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="110dp"
    android:layout_marginTop="5dp"
    android:background="#F6D5E7"
    android:orientation="horizontal">


    <ImageView
        android:id="@+id/ivLutemonImage"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginRight="10dp"
        app:srcCompat="@android:drawable/btn_star_big_on" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtLutemonName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lutemonin nimi"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/txtLutemonAttacks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hyökkäykset" />

        <TextView
            android:id="@+id/txtLutemonDefences"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Puolustukset" />

        <TextView
            android:id="@+id/txtLutemonLives"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Elämät" />

        <TextView
            android:id="@+id/txtLutemonExperiencePoints"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kokemuspisteet" />
    </LinearLayout>
</androidx.appcompat.widget.LinearLayoutCompat>
